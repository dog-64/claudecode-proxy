#!/bin/bash

# clc — запуск Claude Code
# glm/по умолчанию → GLM-4.7 через Z.ai (без прокси)
# glm-cloud-ru → GLM-4.7 через Cloud.ru (без прокси)
# sonnet/opus/haiku → модели Anthropic через прокси
# Использование: clc [--model glm|glm-cloud-ru|sonnet|opus|haiku] [аргументы claude]

MODEL="glm"

show_model_list() {
    echo "Доступные модели для claude:" >&2
    echo "" >&2
    echo "  glm          GLM-4.7 через Z.ai (без прокси, по умолчанию)" >&2
    echo "  glm-cloud-ru GLM-4.7 через Cloud.ru (без прокси)" >&2
    echo "  sonnet       Claude Sonnet через Anthropic API (через прокси)" >&2
    echo "  opus         Claude Opus через Anthropic API (через прокси)" >&2
    echo "  haiku        Claude Haiku через Anthropic API (через прокси)" >&2
    exit 0
}

# Массив для хранения аргументов, которые нужно передать в claude
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)
            MODEL="$2"
            shift 2
            ;;
        --model=*)
            MODEL="${1#--model=}"
            shift
            ;;
        --model-list)
            show_model_list
            ;;
        -y|--you-can)
            CLAUDE_ARGS+=("--permission-mode" "bypassPermissions")
            shift
            ;;
        update|mcp)
            exec claude "$@"
            ;;
        *)
            # Сохраняем аргументы, которые не являются --model
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

# NVM
# shellcheck disable=SC1091
[[ -s "$HOME/.nvm/nvm.sh" ]] && {
    source "$HOME/.nvm/nvm.sh"
    nvm use 20 >/dev/null 2>&1 && echo "✅  Node.js $(node --version)" >&2
}

# Общие переменные для Z.ai
setup_zai() {
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
    export NO_PROXY="*" no_proxy="*"
    [[ -z "$ZAI_API_TOKEN" ]] && { echo "❌ ZAI_API_TOKEN не установлен" >&2; exit 1; }

    export ANTHROPIC_AUTH_TOKEN="$ZAI_API_TOKEN"
    export API_TIMEOUT_MS="3000000"
    export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
    export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
    
#   export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.7"
    export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-5"
}

# Общие переменные для Cloud.ru
setup_cloud_ru() {
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
    export NO_PROXY="*" no_proxy="*"
    [[ -z "$CLOUD_RU_API_KEY" ]] && { echo "❌ CLOUD_RU_API_KEY не установлен" >&2; exit 1; }

    export ANTHROPIC_AUTH_TOKEN="$CLOUD_RU_API_KEY"
    export ANTHROPIC_BASE_URL="https://foundation-models.api.cloud.ru/v1"
    export API_TIMEOUT_MS="3000000"
    export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
}

# Общие переменные для Anthropic + прокси
setup_anthropic() {
    # Проверка настроек прокси
    if [[ -z "$PROXY_USER" || -z "$PROXY_HOST" ]]; then
        echo "⚠️  Переменные PROXY_USER/PROXY_HOST не установлены" >&2
        echo "   Используются значения по умолчанию: user@proxy-server" >&2
        echo "" >&2
        echo "   Для настройки добавь в ~/.zshrc:" >&2
        echo "   export PROXY_USER=\"your-ssh-user\"" >&2
        echo "   export PROXY_HOST=\"your-proxy-host\"" >&2
        echo "" >&2
    fi

    TUNNEL_PID=$(pgrep -f "ssh.*-L.*1080.*${PROXY_USER:-user}@${PROXY_HOST:-proxy-server}")

    [[ -z "$TUNNEL_PID" ]] && {
        echo "🔹 Запуск туннеля 1080 → squid@${PROXY_HOST:-proxy-server}" >&2
        ssh -L 1080:127.0.0.1:3128 -N -f "${PROXY_USER:-user}@${PROXY_HOST:-proxy-server}"
        TUNNEL_PID=$(pgrep -f "ssh.*-L.*1080.*${PROXY_USER:-user}@${PROXY_HOST:-proxy-server}") || {
            echo "❌ Туннель не запущен. Проверь ~/.ssh/config" >&2
            exit 1
        }
    }

    unset NO_PROXY no_proxy 
    unset ANTHROPIC_DEFAULT_SONNET_MODEL  ANTHROPIC_DEFAULT_OPUS_MODEL  ANTHROPIC_BASE_URL  ANTHROPIC_AUTH_TOKEN
    export http_proxy="http://127.0.0.1:1080"
    export https_proxy="http://127.0.0.1:1080"
}

debug_connection() {
  echo "🔍  DEBUG: BASE_URL='$ANTHROPIC_BASE_URL'" >&2
  echo "🔍  DEBUG: MODEL='${ANTHROPIC_DEFAULT_SONNET_MODEL}'" >&2
}

case "$MODEL" in
    glm|default)
        setup_zai

        debug_connection
        echo "🤖  ${ANTHROPIC_DEFAULT_SONNET_MODEL} через Z.ai (без прокси)" >&2
        exec claude "${CLAUDE_ARGS[@]}"
        ;;

    glm-cloud-ru)
        # GLM-4.7 через Cloud.ru (без прокси)
        setup_cloud_ru
        export ANTHROPIC_DEFAULT_SONNET_MODEL="GLM-4.7"

        echo "🤖 GLM-4.7 через Cloud.ru (без прокси)" >&2

        debug_connection
        exec claude "${CLAUDE_ARGS[@]}"
        ;;

    sonnet|opus|haiku)
        echo  "sonnet"
        setup_anthropic

        TEMP_SETTINGS=$(mktemp)
        echo "{}" > "$TEMP_SETTINGS"
        trap 'rm -f "$TEMP_SETTINGS"' EXIT

        echo "🚀 $MODEL через Anthropic + прокси $http_proxy" >&2
        exec claude --model "$MODEL" --setting-sources local --settings "$TEMP_SETTINGS" "${CLAUDE_ARGS[@]}"
#        exec claude --model "$MODEL" "$@"
        ;;

    *)
        echo "❌ Неверная модель: $MODEL" >&2
        echo "   Допустимо: glm, glm-cloud-ru, sonnet, opus, haiku" >&2
        exit 1
        ;;
esac
