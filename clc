#!/bin/bash

# Имя: clc — запуск Claude Code через прокси
# Назначение: Автоматически использует SSH-туннель к dog@vdsina и squid
# Использование: clc [--model glm|sonnet|opus|haiku] [--thinking] [другие аргументы claude]

# Значения по умолчанию
MODEL="glm"
THINKING=""

# Парсинг аргументов
while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)
            MODEL="$2"
            shift 2
            ;;
        --thinking)
            THINKING="enabled"
            shift
            ;;
        update|mcp)
            # Команды, которые не требуют прокси-туннеля
            exec claude "$@"
            ;;
        *)
            break
            ;;
    esac
done

# Проверяем валидность модели
if [[ "$MODEL" != "glm" && "$MODEL" != "sonnet" && "$MODEL" != "opus" && "$MODEL" != "haiku" ]]; then
    echo "❌ Неверная модель: $MODEL" >&2
    echo "   Допустимые значения: glm, sonnet, opus, haiku" >&2
    exit 1
fi

# Проверяем и загружаем nvm для Node.js 20
if [ -s "$HOME/.nvm/nvm.sh" ]; then
    source "$HOME/.nvm/nvm.sh"
    echo "🔧 Переключаюсь на Node.js 20..." >&2
    nvm use 20 >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "✅ Node.js $(node --version) активирован" >&2
    else
        echo "⚠️ Не удалось переключиться на Node.js 20, продолжаю с текущей версией" >&2
    fi
else
    echo "⚠️ nvm не найден, продолжаю без переключения версии Node.js" >&2
fi

TUNNEL_LOCAL_PORT=1080
SSH_TARGET="dog@vdsina"
PROXY_URL="http://127.0.0.1:$TUNNEL_LOCAL_PORT"

# Настройка переменных окружения для выбранной модели
if [[ "$MODEL" == "glm" ]]; then
    # Для GLM отключаем прокси — API Z.ai доступен напрямую из России
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
    export NO_PROXY="*" no_proxy="*"

    # Проверяем наличие необходимых переменных окружения
    if [[ -z "$ZAI_API_TOKEN" ]]; then
        echo "❌ Переменная ZAI_API_TOKEN не установлена" >&2
        echo "   Добавь в ~/.zshrc или ~/.bashrc:" >&2
        echo "   export ZAI_API_TOKEN=\"твой_токен\"" >&2
        exit 1
    fi

    export ANTHROPIC_AUTH_TOKEN="$ZAI_API_TOKEN"
    export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
    export ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
    export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.7"
    export ANTHROPIC_DEFAULT_OPUS_MODEL="glm-4.7"
    export API_TIMEOUT_MS="3000000"
    export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

    # Extended Thinking для GLM
    if [[ "$THINKING" == "enabled" ]]; then
        export MAX_THINKING_TOKENS=200000
        echo "🤖 Используется модель: GLM (glm-4.7 через Z.ai)" >&2
        echo "🧠 Extended Thinking: ВКЛЮЧЁН (MAX_THINKING_TOKENS=200000)" >&2
    else
        echo "🤖 Используется модель: GLM (glm-4.7 через Z.ai)" >&2
        echo "💡 Используй --thinking для включения режима расширенного мышления" >&2
    fi
    echo "🌐 Работает напрямую, БЕЗ прокси (API Z.ai доступен из РФ)" >&2
else
    # Для sonnet/opus/haiku используем оригинальный API Anthropic (подписка)
    # Нужен прокси, так как API Anthropic заблокирован в РФ

    # Проверяем и запускаем туннель только если нужен прокси
    TUNNEL_PID=$(pgrep -f "ssh.*-L.*$TUNNEL_LOCAL_PORT.*dog@vdsina")

    if [ -z "$TUNNEL_PID" ]; then
        echo "🔹 Запускаю SSH-туннель: $TUNNEL_LOCAL_PORT → squid на $SSH_TARGET" >&2
        ssh -L $TUNNEL_LOCAL_PORT:127.0.0.1:3128 -N -f $SSH_TARGET
        TUNNEL_PID=$(pgrep -f "ssh.*-L.*$TUNNEL_LOCAL_PORT.*dog@vdsina")
        if [ -z "$TUNNEL_PID" ]; then
            echo "❌ Не удалось запустить туннель. Проверь:" >&2
            echo "   - Имя хоста 'vdsina' в ~/.ssh/config" >&2
            echo "   - Наличие SSH-ключа для пользователя 'dog'" >&2
            exit 1
        fi
        echo "✅ Туннель запущен (PID: $TUNNEL_PID)" >&2
    else
        echo "🔹 Использую существующий туннель (PID: $TUNNEL_PID)" >&2
    fi

    # Устанавливаем прокси
    unset NO_PROXY no_proxy
    export http_proxy=$PROXY_URL
    export https_proxy=$PROXY_URL

    # Отключаем настройки Z.ai через временный конфиг
    TEMP_SETTINGS=$(mktemp)
    cat > "$TEMP_SETTINGS" << 'EOF'
{}
EOF
    if [[ "$MODEL" == "sonnet" ]]; then
        echo "🧠 Используется модель: Sonnet (оригинальный Anthropic, через прокси)" >&2
    elif [[ "$MODEL" == "opus" ]]; then
        echo "🚀 Используется модель: Opus (оригинальный Anthropic, через прокси)" >&2
    elif [[ "$MODEL" == "haiku" ]]; then
        echo "⚡ Используется модель: Haiku (оригинальный Anthropic, через прокси)" >&2
    fi
    echo "🌐 Работает через прокси: $PROXY_URL" >&2
    echo "💡 Трафик идёт через squid на 109.234.34.112 (vdsina)" >&2
fi

# Запуск
if [[ "$MODEL" == "sonnet" || "$MODEL" == "opus" || "$MODEL" == "haiku" ]]; then
    exec claude --model "$MODEL" --setting-sources local --settings "$TEMP_SETTINGS" "$@"
    rm -f "$TEMP_SETTINGS"
else
    exec claude "$@"
fi
