#!/bin/bash

# clc — запуск Claude Code (GLM напрямую, остальные через прокси)

MODEL="glm"
THINKING=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)  MODEL="$2"; shift 2 ;;
        --thinking) THINKING=1; shift ;;
        update|mcp) exec claude "$@" ;;
        *) break ;;
    esac
done

# Валидация и описание моделей
case "$MODEL" in
    glm)   MODEL_NAME="GLM (glm-4.7)"      PROXY=direct ICON="🤖" ;;
    sonnet) MODEL_NAME="Sonnet"            PROXY=tunnel ICON="🧠" ;;
    opus)   MODEL_NAME="Opus"              PROXY=tunnel ICON="🚀" ;;
    haiku)  MODEL_NAME="Haiku"             PROXY=tunnel ICON="⚡" ;;
    *)      echo "❌ Неверная модель: $MODEL (допустимо: glm, sonnet, opus, haiku)" >&2; exit 1 ;;
esac

# Нормализация для Claude Code (ожидает Opus, Sonnet, Haiku)
case "$MODEL" in
    sonnet) MODEL="Sonnet" ;;
    opus) MODEL="Opus" ;;
    haiku) MODEL="Haiku" ;;
esac

# NVM
[[ -s "$HOME/.nvm/nvm.sh" ]] && {
    source "$HOME/.nvm/nvm.sh"
    nvm use 20 >/dev/null 2>&1 && echo "✅ Node.js $(node --version)" >&2
}

if [[ "$PROXY" == "direct" ]]; then
    # GLM — без прокси
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
    export NO_PROXY="*" no_proxy="*"
    [[ -z "$ZAI_API_TOKEN" ]] && { echo "❌ ZAI_API_TOKEN не установлен" >&2; exit 1; }

    export ANTHROPIC_AUTH_TOKEN="$ZAI_API_TOKEN"
    export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
    export ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
    export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.7"
    export ANTHROPIC_DEFAULT_OPUS_MODEL="glm-4.7"
    export API_TIMEOUT_MS="3000000"
    export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

    [[ "$THINKING" ]] && export MAX_THINKING_TOKENS=200000

    echo "$ICON $MODEL_NAME через Z.ai, без прокси" >&2
    [[ "$THINKING" ]] && echo "🧠 Extended Thinking включён" >&2

    exec claude "$@"
else
    # Sonnet/Opus/Haiku — через прокси
    TUNNEL_PID=$(pgrep -f "ssh.*-L.*1080.*dog@vdsina")

    [[ -z "$TUNNEL_PID" ]] && {
        echo "🔹 Запуск туннеля 1080 → squid@vdsina" >&2
        ssh -L 1080:127.0.0.1:3128 -N -f dog@vdsina
        TUNNEL_PID=$(pgrep -f "ssh.*-L.*1080.*dog@vdsina") || {
            echo "❌ Туннель не запущен. Проверь ~/.ssh/config" >&2
            exit 1
        }
    }

    unset NO_PROXY no_proxy
    export http_proxy=https_proxy="http://127.0.0.1:1080"

    TEMP_SETTINGS=$(mktemp)
    echo "{}" > "$TEMP_SETTINGS"
    trap 'rm -f "$TEMP_SETTINGS"' EXIT

    echo "$ICON $MODEL_NAME через Anthropic + прокси" >&2

    exec claude --model "$MODEL" --setting-sources local --settings "$TEMP_SETTINGS" "$@"
fi